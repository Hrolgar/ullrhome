# Sanity Configuration
# Create a project at https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token (for server-side fetching)
# Create at: https://www.sanity.io/manage → API → Tokens → Add API token (Viewer role)
SANITY_API_TOKEN=your-api-token

# Secret for on-demand revalidation webhook
# Generate with: openssl rand -hex 32
SANITY_REVALIDATE_SECRET=your-revalidate-secret

# Public site URL (used for sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=https://ullrhome.com
